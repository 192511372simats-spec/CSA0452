#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <dirent.h>

int main()
{
    int fd;
    char buffer[100];
    struct stat fileStat;
    DIR *dir;
    struct dirent *entry;

    // -------------------- OPEN FILE --------------------
    fd = open("sample.txt", O_CREAT | O_RDWR | O_TRUNC, 0644);

    if (fd == -1)
    {
        perror("Error opening file");
        return 1;
    }

    // -------------------- WRITE INTO FILE --------------------
    write(fd, "Hello UNIX System Calls!", 25);
    printf("File 'sample.txt' created and written successfully.\n");

    // -------------------- FCNTL --------------------
    int flags = fcntl(fd, F_GETFL);
    if (flags == -1)
    {
        perror("fcntl failed");
        close(fd);
        return 1;
    }

    printf("\n--- fcntl() Output ---\n");
    printf("File flags value: %d\n", flags);

    // -------------------- LSEEK --------------------
    lseek(fd, 0, SEEK_SET);

    read(fd, buffer, 25);
    buffer[25] = '\0';

    printf("\n--- lseek() Output ---\n");
    printf("File content after seek: %s\n", buffer);

    close(fd);

    // -------------------- STAT --------------------
    if (stat("sample.txt", &fileStat) == -1)
    {
        perror("stat failed");
        return 1;
    }

    printf("\n--- stat() Output ---\n");
    printf("File Size: %ld bytes\n", fileStat.st_size);
    printf("Permissions: %o\n", fileStat.st_mode & 0777);
    printf("No. of Links: %ld\n", fileStat.st_nlink);

    // -------------------- OPENDIR & READDIR --------------------
    printf("\n--- opendir() and readdir() Output ---\n");

    dir = opendir(".");
    if (dir == NULL)
    {
        perror("opendir failed");
        return 1;
    }

    printf("Files in current directory:\n");
    while ((entry = readdir(dir)) != NULL)
    {
        printf("%s\n", entry->d_name);
    }

    closedir(dir);

    return 0;
}
