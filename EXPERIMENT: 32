#include <stdio.h>

int main() {
    int pages[30], frames[10], recent[10];
    int n, f, i, j, time = 0, fault = 0, found, min, pos;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter reference string: ");
    for (i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &f);

    for (i = 0; i < f; i++) {
        frames[i] = -1;
        recent[i] = 0;
    }

    for (i = 0; i < n; i++) {
        found = 0;
        time++;

        for (j = 0; j < f; j++) {
            if (frames[j] == pages[i]) {
                found = 1;
                recent[j] = time;
                break;
            }
        }

        if (!found) {
            pos = 0;
            min = recent[0];

            for (j = 0; j < f; j++) {
                if (frames[j] == -1) {
                    pos = j;
                    break;
                }
                if (recent[j] < min) {
                    min = recent[j];
                    pos = j;
                }
            }

            frames[pos] = pages[i];
            recent[pos] = time;
            fault++;
        }

        printf("Frames: ");
        for (j = 0; j < f; j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Total Page Faults = %d\n", fault);
    return 0;
}
