#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <unistd.h>
#include <string.h>

int main() {
    int shmid;
    char *shared_memory;

    // Create shared memory of size 100 bytes
    shmid = shmget(IPC_PRIVATE, 100, IPC_CREAT | 0666);

    // Attach shared memory
    shared_memory = (char *)shmat(shmid, NULL, 0);

    if (fork() == 0) {
        // Child process reads from shared memory
        sleep(1);  // wait for parent to write
        printf("Child reads: %s\n", shared_memory);
    } 
    else {
        // Parent process writes into shared memory
        strcpy(shared_memory, "Hello from Parent using Shared Memory!");
        printf("Parent wrote message.\n");
        sleep(2);
    }

    // Detach shared memory
    shmdt(shared_memory);

    return 0;
}

OUTPUT:
Parent wrote message.
Child reads: Hello from Parent using Shared Memory!
