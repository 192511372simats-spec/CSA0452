#include <stdio.h>
#include <stdlib.h>

int main() {
    int req[20], n, head, i, j, disk_size = 200;
    int total = 0, temp;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request sequence: ");
    for (i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    // sort
    for (i = 0; i < n; i++) {
        for (j = i + 1; j < n; j++) {
            if (req[i] > req[j]) {
                temp = req[i];
                req[i] = req[j];
                req[j] = temp;
            }
        }
    }

    int pos;
    for (i = 0; i < n; i++) {
        if (req[i] > head) {
            pos = i;
            break;
        }
    }

    // Move right
    for (i = pos; i < n; i++) {
        total += abs(req[i] - head);
        head = req[i];
    }

    // Move to end
    total += abs((disk_size - 1) - head);
    head = disk_size - 1;

    // Move left
    for (i = pos - 1; i >= 0; i--) {
        total += abs(req[i] - head);
        head = req[i];
    }

    printf("Total Head Movement = %d\n", total);
    return 0;
}
