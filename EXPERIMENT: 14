#include <stdio.h>
#include <string.h>

int main() {
    char files[10][20];
    int choice, count = 0;

    while (1) {
        printf("\n--- Single Level Directory ---\n");
        printf("1. Create File\n");
        printf("2. Delete File\n");
        printf("3. Display Files\n");
        printf("4. Exit\n");

        printf("Enter choice: ");
        scanf("%d", &choice);

        if (choice == 1) {
            printf("Enter file name: ");
            scanf("%s", files[count]);
            count++;
            printf("File created successfully.\n");
        }
        else if (choice == 4) {
            break;
        }
    }

    return 0;
}

